{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spritex",
  "version": "0.1.0",
  "identifier": "com.spritex.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Spritex",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzODYyNjA4NEFGNDI5RkYKUldUL0tmUktDQ2FHbzFiWXo1SG9QQlhJeEI4dmFGcDU4d3U0QzBCRHdGWmpDeDZzK1g3R0dheHIK",
      "endpoints": ["https://github.com/Nyanez615/Spritex/releases/latest/download/latest.json"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/static.db"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
